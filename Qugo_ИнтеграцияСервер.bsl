// Общий модуль: Qugo_ИнтеграцияСервер
// Назначение: авторизация и синхронизация исполнителей с API Qugo
// Параметры общего модуля: Сервер = Истина, ВызовСервера = Истина, КлиентОбычноеПриложение = Истина

#Область ПрограммныйИнтерфейс

// Загружает исполнителей из API Qugo (endpoint /sync/workmans).
//
// Параметры:
//   Токен        - Строка - ключ авторизации Bearer. Если Неопределено — берётся из Константы.Qugo_КлючАвторизации.
//   ДатаЗагрузки - Дата - дата, начиная с которой запрашиваются изменения (UpdateSince).
//                       Если Неопределено — берётся из Константы.Qugo_ДатаЗагрузкиИсполнителей.
//
Процедура Qugo_ЗагрузкаИсполнителей(Токен = Неопределено, ДатаЗагрузки = Неопределено) Экспорт
	
	Если Токен = Неопределено Тогда
		Токен = Константы.Qugo_КлючАвторизации.Получить();
	КонецЕсли;
	
	Если ПустаяСтрока(Токен) Тогда
		ВызватьИсключение НСтр("ru = 'Не указан ключ авторизации Qugo (константа Qugo_КлючАвторизации).'");
	КонецЕсли;
	
	Если ДатаЗагрузки = Неопределено Тогда
		ДатаЗагрузки = Константы.Qugo_ДатаЗагрузкиИсполнителей.Получить();
	КонецЕсли;
	
	БазовыйURL = "https://integration.demo.qugo.ru/api/v1";
	РазмерСтраницы = 25;
	ИдентификаторСобытия = Новый УникальныйИдентификатор();
	
	КоличествоЗагружено = 0;
	ИндексСтраницы = 1;
	ЕстьДанные = Истина;
	
	Пока ЕстьДанные Цикл
		
		ПараметрыЗапроса = Новый Соответствие;
		ПараметрыЗапроса.Вставить("UpdateSince", Формат(ДатаЗагрузки, "ДФ=yyyy-MM-dd"));
		ПараметрыЗапроса.Вставить("pageindex", Формат(ИндексСтраницы, "ЧГ="));
		ПараметрыЗапроса.Вставить("pagesize", Формат(РазмерСтраницы, "ЧГ="));
		
		Попытка
			ТекстОтвета = ВыполнитьHTTPЗапрос(БазовыйURL, "/sync/workmans", ПараметрыЗапроса, Токен);
		Исключение
			ОписаниеОшибки = ОписаниеОшибки();
			ЗаписатьСобытиеВЖурнал(ИдентификаторСобытия, Ложь, ИндексСтраницы, ОписаниеОшибки);
			ВызватьИсключение ОписаниеОшибки;
		КонецПопытки;
		
		МассивИсполнителей = РазобратьМассивИсполнителей(ТекстОтвета);
		
		Если МассивИсполнителей.Количество() = 0 Тогда
			ЕстьДанные = Ложь;
			Продолжить;
		КонецЕсли;
		
		Для Каждого ДанныеИсполнителя Из МассивИсполнителей Цикл
			ЗаписатьИсполнителя(ДанныеИсполнителя);
			КоличествоЗагружено = КоличествоЗагружено + 1;
		КонецЦикла;
		
		ЗаписатьСобытиеВЖурнал(ИдентификаторСобытия, Истина, ИндексСтраницы, "");
		
		Если МассивИсполнителей.Количество() < РазмерСтраницы Тогда
			ЕстьДанные = Ложь;
		КонецЕсли;
		
		ИндексСтраницы = ИндексСтраницы + 1;
		
	КонецЦикла;
	
	Константы.Qugo_ДатаЗагрузкиИсполнителей.Установить(ТекущаяДатаСеанса());
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = СтрШаблон(НСтр("ru = 'Загрузка исполнителей завершена. Загружено записей: %1'"), Формат(КоличествоЗагружено, "ЧГ="));
	Сообщение.Сообщить();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет HTTP-запрос GET к API Qugo с авторизацией Bearer.
//
// Параметры:
//   БазовыйURL         - Строка - базовый URL API (без пути ресурса).
//   ОтносительныйURL   - Строка - путь ресурса (начинается с /).
//   ПараметрыЗапроса   - Соответствие - параметры query string.
//   Токен              - Строка - Bearer-токен.
//
// Возвращаемое значение:
//   Строка - тело ответа (JSON).
//
Функция ВыполнитьHTTPЗапрос(БазовыйURL, ОтносительныйURL, ПараметрыЗапроса, Токен)
	
	Сервер = СтрРазделить(БазовыйURL, "/")[2];
	Порт = 443;
	
	ПолныйПуть = ОтносительныйURL;
	Если ПараметрыЗапроса.Количество() > 0 Тогда
		Части = Новый Массив;
		Для Каждого КлючЗначение Из ПараметрыЗапроса Цикл
			Части.Добавить(КлючЗначение.Ключ + "=" + КлючЗначение.Значение);
		КонецЦикла;
		ПолныйПуть = ПолныйПуть + "?" + СтрСоединить(Части, "&");
	КонецЕсли;
	
	HTTPЗапрос = Новый HTTPЗапрос(ПолныйПуть);
	HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + Токен);
	HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");
	
	Соединение = Новый HTTPСоединение(Сервер, Порт, , , , 10, Новый ЗащищенноеСоединениеOpenSSL());
	
	HTTPОтвет = Соединение.Получить(HTTPЗапрос);
	
	Если HTTPОтвет.КодСостояния >= 400 Тогда
		ТекстОшибки = "";
		Попытка
			ТекстОшибки = ПрочитатьТелоОтвета(HTTPОтвет);
		Исключение
		КонецПопытки;
		ВызватьИсключение СтрШаблон(НСтр("ru = 'HTTP-ошибка. Код: %1, Тело: %2'"), HTTPОтвет.КодСостояния, ТекстОшибки);
	КонецЕсли;
	
	Возврат ПрочитатьТелоОтвета(HTTPОтвет);
	
КонецФункции

// Разбирает JSON-ответ API и возвращает массив исполнителей.
//
// Параметры:
//   ТекстОтвета - Строка - тело JSON-ответа.
//
// Возвращаемое значение:
//   Массив - массив объектов Соответствие с данными исполнителей.
//
Функция РазобратьМассивИсполнителей(ТекстОтвета)
	
	МассивРезультат = Новый Массив;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстОтвета);
	
	ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Если ТипЗнч(ДанныеОтвета) = Тип("Массив") Тогда
		Возврат ДанныеОтвета;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеОтвета) = Тип("Соответствие") Или ТипЗнч(ДанныеОтвета) = Тип("Структура") Тогда
		
		Для Каждого КлючЗначение Из ДанныеОтвета Цикл
			Если ТипЗнч(КлючЗначение.Значение) = Тип("Массив") Тогда
				Возврат КлючЗначение.Значение;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат МассивРезультат;
	
КонецФункции

// Создаёт или обновляет элемент справочника Qugo_Исполнители по данным из JSON.
//
// Параметры:
//   ДанныеИсполнителя - Соответствие - данные исполнителя из JSON-ответа API.
//
Процедура ЗаписатьИсполнителя(ДанныеИсполнителя)
	
	ИдентификаторQugo = ПолучитьСвойство(ДанныеИсполнителя, "id", "");
	ИНН = ПолучитьСвойство(ДанныеИсполнителя, "inn", "");
	Фамилия = ПолучитьСвойство(ДанныеИсполнителя, "lastName", "");
	Имя = ПолучитьСвойство(ДанныеИсполнителя, "firstName", "");
	Отчество = ПолучитьСвойство(ДанныеИсполнителя, "middleName", "");
	
	Ссылка = НайтиСсылкуИсполнителя(ИдентификаторQugo, ИНН);
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Объект = Ссылка.ПолучитьОбъект();
	Иначе
		Объект = Справочники.Qugo_Исполнители.СоздатьЭлемент();
	КонецЕсли;
	
	Если Не ПустаяСтрока(ИдентификаторQugo) Тогда
		Объект.ИдентификаторQugo = ИдентификаторQugo;
	КонецЕсли;
	
	Если Не ПустаяСтрока(ИНН) Тогда
		Объект.ИНН = ИНН;
	КонецЕсли;
	
	Объект.Наименование = СформироватьНаименование(Фамилия, Имя, Отчество, ИНН);
	
	Объект.Фамилия = Фамилия;
	Объект.Имя = Имя;
	Объект.Отчество = Отчество;
	
	Телефон = ПолучитьСвойство(ДанныеИсполнителя, "phone", "");
	Если Не ПустаяСтрока(Телефон) Тогда
		Объект.Телефон = Телефон;
	КонецЕсли;
	
	Email = ПолучитьСвойство(ДанныеИсполнителя, "email", "");
	Если Не ПустаяСтрока(Email) Тогда
		Объект.Email = Email;
	КонецЕсли;
	
	СНИЛС = ПолучитьСвойство(ДанныеИсполнителя, "snils", "");
	Если Не ПустаяСтрока(СНИЛС) Тогда
		Объект.СНИЛС = СНИЛС;
	КонецЕсли;
	
	ДатаРожденияСтр = ПолучитьСвойство(ДанныеИсполнителя, "birthDate", "");
	ДатаРождения = ПреобразоватьДатуИзСтроки(ДатаРожденияСтр);
	Если ЗначениеЗаполнено(ДатаРождения) Тогда
		Объект.ДатаРождения = ДатаРождения;
	КонецЕсли;
	
	МестоРождения = ПолучитьСвойство(ДанныеИсполнителя, "birthPlace", "");
	Если Не ПустаяСтрока(МестоРождения) Тогда
		Объект.МестоРождения = МестоРождения;
	КонецЕсли;
	
	ЗначениеПола = ПолучитьСвойство(ДанныеИсполнителя, "gender", "");
	Если Не ПустаяСтрока(ЗначениеПола) Тогда
		Объект.Пол = ОпределитьПол(ЗначениеПола);
	КонецЕсли;
	
	ЗначениеНалоговогоСтатуса = ПолучитьСвойство(ДанныеИсполнителя, "taxStatus", "");
	Если Не ПустаяСтрока(ЗначениеНалоговогоСтатуса) Тогда
		Объект.НалоговыйСтатус = ОпределитьНалоговыйСтатус(ЗначениеНалоговогоСтатуса);
	КонецЕсли;
	
	ПаспортСерия = ПолучитьСвойство(ДанныеИсполнителя, "passportSeries", "");
	Если Не ПустаяСтрока(ПаспортСерия) Тогда
		Объект.СерияПаспорта = ПаспортСерия;
	КонецЕсли;
	
	ПаспортНомер = ПолучитьСвойство(ДанныеИсполнителя, "passportNumber", "");
	Если Не ПустаяСтрока(ПаспортНомер) Тогда
		Объект.НомерПаспорта = ПаспортНомер;
	КонецЕсли;
	
	КемВыданПаспорт = ПолучитьСвойство(ДанныеИсполнителя, "passportIssuedBy", "");
	Если Не ПустаяСтрока(КемВыданПаспорт) Тогда
		Объект.КемВыданПаспорт = КемВыданПаспорт;
	КонецЕсли;
	
	ДатаВыдачиПаспорта = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "passportIssueDate", ""));
	Если ЗначениеЗаполнено(ДатаВыдачиПаспорта) Тогда
		Объект.ДатаВыдачиПаспорта = ДатаВыдачиПаспорта;
	КонецЕсли;
	
	ДатаОкончанияПаспорта = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "passportExpiryDate", ""));
	Если ЗначениеЗаполнено(ДатаОкончанияПаспорта) Тогда
		Объект.ДатаОкончанияПаспорта = ДатаОкончанияПаспорта;
	КонецЕсли;
	
	КодПодразделения = ПолучитьСвойство(ДанныеИсполнителя, "passportDepartmentCode", "");
	Если Не ПустаяСтрока(КодПодразделения) Тогда
		Объект.КодПодразделения = КодПодразделения;
	КонецЕсли;
	
	АдресРегистрации = ПолучитьСвойство(ДанныеИсполнителя, "registrationAddress", "");
	Если Не ПустаяСтрока(АдресРегистрации) Тогда
		Объект.АдресРегистрации = АдресРегистрации;
	КонецЕсли;
	
	НомерКарты = ПолучитьСвойство(ДанныеИсполнителя, "cardNumber", "");
	Если Не ПустаяСтрока(НомерКарты) Тогда
		Объект.НомерКарты = НомерКарты;
	КонецЕсли;
	
	РасчетныйСчет = ПолучитьСвойство(ДанныеИсполнителя, "bankAccount", "");
	Если Не ПустаяСтрока(РасчетныйСчет) Тогда
		Объект.РасчетныйСчет = РасчетныйСчет;
	КонецЕсли;
	
	БИКБанка = ПолучитьСвойство(ДанныеИсполнителя, "bankBik", "");
	Если Не ПустаяСтрока(БИКБанка) Тогда
		Объект.БИКБанка = БИКБанка;
	КонецЕсли;
	
	ПатентСерия = ПолучитьСвойство(ДанныеИсполнителя, "patentSeries", "");
	Если Не ПустаяСтрока(ПатентСерия) Тогда
		Объект.ПатентСерия = ПатентСерия;
	КонецЕсли;
	
	ПатентНомер = ПолучитьСвойство(ДанныеИсполнителя, "patentNumber", "");
	Если Не ПустаяСтрока(ПатентНомер) Тогда
		Объект.ПатентНомер = ПатентНомер;
	КонецЕсли;
	
	ПатентРегион = ПолучитьСвойство(ДанныеИсполнителя, "patentRegion", "");
	Если Не ПустаяСтрока(ПатентРегион) Тогда
		Объект.ПатентРегион = ПатентРегион;
	КонецЕсли;
	
	ПатентПрофессия = ПолучитьСвойство(ДанныеИсполнителя, "patentProfession", "");
	Если Не ПустаяСтрока(ПатентПрофессия) Тогда
		Объект.ПатентПрофессия = ПатентПрофессия;
	КонецЕсли;
	
	ПатентДатаОкончания = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "patentExpiryDate", ""));
	Если ЗначениеЗаполнено(ПатентДатаОкончания) Тогда
		Объект.ПатентДатаОкончания = ПатентДатаОкончания;
	КонецЕсли;
	
	МедКнижка = ПолучитьСвойство(ДанныеИсполнителя, "hasMedicalBook", Неопределено);
	Если МедКнижка <> Неопределено Тогда
		Объект.МедКнижка = МедКнижка;
	КонецЕсли;
	
	СправкаОНесудимости = ПолучитьСвойство(ДанныеИсполнителя, "hasNoCriminalRecordCertificate", Неопределено);
	Если СправкаОНесудимости <> Неопределено Тогда
		Объект.СправкаОНесудимости = СправкаОНесудимости;
	КонецЕсли;
	
	ВСтопЛисте = ПолучитьСвойство(ДанныеИсполнителя, "inStopList", Неопределено);
	Если ВСтопЛисте <> Неопределено Тогда
		Объект.ВСтопЛисте = ВСтопЛисте;
	КонецЕсли;
	
	СтатусQugo = ПолучитьСвойство(ДанныеИсполнителя, "isActive", Неопределено);
	Если СтатусQugo <> Неопределено Тогда
		Объект.СтатусQugo = СтатусQugo;
	КонецЕсли;
	
	МиграционнаяКартаДатаНачала = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "migrationCardStartDate", ""));
	Если ЗначениеЗаполнено(МиграционнаяКартаДатаНачала) Тогда
		Объект.МиграционнаяКартаДатаНачала = МиграционнаяКартаДатаНачала;
	КонецЕсли;
	
	МиграционнаяКартаДатаОкончания = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "migrationCardEndDate", ""));
	Если ЗначениеЗаполнено(МиграционнаяКартаДатаОкончания) Тогда
		Объект.МиграционнаяКартаДатаОкончания = МиграционнаяКартаДатаОкончания;
	КонецЕсли;
	
	МедОсвидетельствованиеДатаВыдачи = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "medicalExaminationDate", ""));
	Если ЗначениеЗаполнено(МедОсвидетельствованиеДатаВыдачи) Тогда
		Объект.МедОсвидетельствованиеДатаВыдачи = МедОсвидетельствованиеДатаВыдачи;
	КонецЕсли;
	
	ДактилоскопияДатаВыдачи = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "dactyloscopyDate", ""));
	Если ЗначениеЗаполнено(ДактилоскопияДатаВыдачи) Тогда
		Объект.Дактилоскопия_ДатаВыдачи = ДактилоскопияДатаВыдачи;
	КонецЕсли;
	
	СрокДействияЛистаРегистрации = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "registrationSheetExpiryDate", ""));
	Если ЗначениеЗаполнено(СрокДействияЛистаРегистрации) Тогда
		Объект.СрокДействияЛистаРегистрации = СрокДействияЛистаРегистрации;
	КонецЕсли;
	
	КвитанцияДатаНачала = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "patentPaymentReceiptStartDate", ""));
	Если ЗначениеЗаполнено(КвитанцияДатаНачала) Тогда
		Объект.КвитанцияНаОплатуПатентаДатаНачала = КвитанцияДатаНачала;
	КонецЕсли;
	
	КвитанцияДатаОкончания = ПреобразоватьДатуИзСтроки(ПолучитьСвойство(ДанныеИсполнителя, "patentPaymentReceiptEndDate", ""));
	Если ЗначениеЗаполнено(КвитанцияДатаОкончания) Тогда
		Объект.КвитанцияНаОплатуПатентаДатаОкончания = КвитанцияДатаОкончания;
	КонецЕсли;
	
	Объект.Записать();
	
КонецПроцедуры

// Ищет существующего исполнителя по идентификатору Qugo или ИНН.
//
// Параметры:
//   ИдентификаторQugo - Строка - внешний идентификатор.
//   ИНН               - Строка - ИНН.
//
// Возвращаемое значение:
//   СправочникСсылка.Qugo_Исполнители - найденная ссылка, или пустая ссылка если не найден.
//
Функция НайтиСсылкуИсполнителя(ИдентификаторQugo, ИНН)
	
	Если Не ПустаяСтрока(ИдентификаторQugo) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Qugo_Исполнители.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Qugo_Исполнители КАК Qugo_Исполнители
			|ГДЕ
			|	Qugo_Исполнители.ИдентификаторQugo = &ИдентификаторQugo";
		Запрос.УстановитьПараметр("ИдентификаторQugo", ИдентификаторQugo);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПустаяСтрока(ИНН) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Qugo_Исполнители.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Qugo_Исполнители КАК Qugo_Исполнители
			|ГДЕ
			|	Qugo_Исполнители.ИНН = &ИНН";
		Запрос.УстановитьПараметр("ИНН", ИНН);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Qugo_Исполнители.ПустаяСсылка();
	
КонецФункции

// Формирует наименование элемента справочника по ФИО.
//
Функция СформироватьНаименование(Фамилия, Имя, Отчество, ИНН)
	
	Части = Новый Массив;
	
	Если Не ПустаяСтрока(Фамилия) Тогда
		Части.Добавить(Фамилия);
	КонецЕсли;
	
	Если Не ПустаяСтрока(Имя) Тогда
		Части.Добавить(Лев(Имя, 1) + ".");
	КонецЕсли;
	
	Если Не ПустаяСтрока(Отчество) Тогда
		Части.Добавить(Лев(Отчество, 1) + ".");
	КонецЕсли;
	
	Наименование = СтрСоединить(Части, " ");
	
	Если ПустаяСтрока(Наименование) И Не ПустаяСтрока(ИНН) Тогда
		Наименование = ИНН;
	КонецЕсли;
	
	Возврат Наименование;
	
КонецФункции

// Возвращает значение свойства из Соответствия или Структуры по имени.
// Если свойство отсутствует — возвращает ЗначениеПоУмолчанию.
//
Функция ПолучитьСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию)
	
	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Если Данные.Получить(ИмяСвойства) <> Неопределено Тогда
			Возврат Данные.Получить(ИмяСвойства);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Данные) = Тип("Структура") Тогда
		Если Данные.Свойство(ИмяСвойства) Тогда
			Возврат Данные[ИмяСвойства];
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

// Преобразует строку ISO-даты (YYYY-MM-DD или YYYY-MM-DDThh:mm:ss) в дату 1С.
//
Функция ПреобразоватьДатуИзСтроки(Знач СтрокаДаты)
	
	Если ПустаяСтрока(СтрокаДаты) Тогда
		Возврат '00010101';
	КонецЕсли;
	
	Попытка
		Возврат XMLЗначение(Тип("Дата"), СтрокаДаты);
	Исключение
	КонецПопытки;
	
	Возврат '00010101';
	
КонецФункции

// Определяет значение перечисления Qugo_ПолФизическогоЛица по строковому коду API.
//
Функция ОпределитьПол(Знач ЗначениеПола)
	
	ЗначениеПола = НРег(СокрЛП(ЗначениеПола));
	
	Если ЗначениеПола = "man" Или ЗначениеПола = "male" Или ЗначениеПола = "м" Или ЗначениеПола = "мужской" Тогда
		Возврат Перечисления.Qugo_ПолФизическогоЛица.Мужской;
	ИначеЕсли ЗначениеПола = "woman" Или ЗначениеПола = "female" Или ЗначениеПола = "ж" Или ЗначениеПола = "женский" Тогда
		Возврат Перечисления.Qugo_ПолФизическогоЛица.Женский;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Определяет значение перечисления Qugo_НалоговыйСтатусИсполнителя по строковому коду API.
//
Функция ОпределитьНалоговыйСтатус(Знач ЗначениеСтатуса)
	
	ЗначениеСтатуса = НРег(СокрЛП(ЗначениеСтатуса));
	
	Если ЗначениеСтатуса = "smz" Тогда
		Возврат Перечисления.Qugo_НалоговыйСтатусИсполнителя.SMZ;
	ИначеЕсли ЗначениеСтатуса = "ip" Тогда
		Возврат Перечисления.Qugo_НалоговыйСтатусИсполнителя.IP;
	ИначеЕсли ЗначениеСтатуса = "ooo" Тогда
		Возврат Перечисления.Qugo_НалоговыйСтатусИсполнителя.OOO;
	ИначеЕсли ЗначениеСтатуса = "pao" Тогда
		Возврат Перечисления.Qugo_НалоговыйСтатусИсполнителя.PAO;
	ИначеЕсли ЗначениеСтатуса = "np" Тогда
		Возврат Перечисления.Qugo_НалоговыйСтатусИсполнителя.NP;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Записывает событие синхронизации в регистр сведений Qugo_ЖурналСобытийИнтеграции.
//
Процедура ЗаписатьСобытиеВЖурнал(ИдентификаторСобытия, Успешно, Страница, ОписаниеОшибки)
	
	Запись = РегистрыСведений.Qugo_ЖурналСобытийИнтеграции.СоздатьМенеджерЗаписи();
	Запись.Период = ТекущаяДатаСеанса();
	Запись.ИдентификаторСобытия = Строка(ИдентификаторСобытия);
	Запись.Успешно = Успешно;
	Запись.Страница = Страница;
	Запись.ОписаниеОшибки = ОписаниеОшибки;
	Запись.Записать();
	
КонецПроцедуры

// Читает тело HTTP-ответа как строку.
//
Функция ПрочитатьТелоОтвета(HTTPОтвет)
	
	Кодировка = Неопределено;
	Возврат HTTPОтвет.ПолучитьТелоКакСтроку(Кодировка);
	
КонецФункции

#КонецОбласти
